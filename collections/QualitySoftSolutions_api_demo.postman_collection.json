									"pm.test(\"Tiempo de respuesta < 700ms\", function () {\r",
									"    pm.expect(pm.response.responseTime).to.be.below(700);\r",
									"});\r",
									"\r",
									"const json = pm.response.json();\r",
									"\r",
									"const users = json.data;\r",
									"\r",
									"console.log(\"ID | Nombre | Email\");\r",
									"users.forEach(u => {\r",
									"    console.log(`${u.id} | ${u.first_name} ${u.last_name} | ${u.email}`);\r",
									"});\r",
									"\r",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
